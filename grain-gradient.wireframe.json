{
  "version": "1.0",
  "theme": "blueprint",
  "root": {
    "id": "root",
    "type": "frame",
    "direction": "vertical",
    "width": "fill",
    "height": "fill",
    "children": [
      {
        "id": "nav",
        "type": "frame",
        "direction": "horizontal",
        "gap": 16,
        "padding": 16,
        "width": "fill",
        "children": [
          {
            "id": "site-name",
            "type": "text",
            "text": "Lyle Klyne",
            "level": "body"
          },
          {
            "id": "nav-spacer",
            "type": "spacer"
          },
          {
            "id": "garden-link",
            "type": "button",
            "text": "Garden",
            "variant": "ghost"
          }
        ]
      },
      {
        "id": "canvas-area",
        "type": "frame",
        "direction": "vertical",
        "width": "fill",
        "height": "fill",
        "padding": 0,
        "children": [
          {
            "id": "gradient-preview",
            "type": "image",
            "width": "fill",
            "height": 400,
            "alt": "Gradient canvas"
          }
        ]
      },
      {
        "id": "bottom-bar",
        "type": "frame",
        "direction": "horizontal",
        "gap": 8,
        "padding": 12,
        "width": "fill",
        "children": [
          {
            "id": "mode-mesh",
            "type": "button",
            "text": "edit",
            "variant": "primary"
          },
          {
            "id": "mode-moon",
            "type": "button",
            "text": "moon",
            "variant": "secondary"
          },
          {
            "id": "bottom-spacer",
            "type": "spacer"
          },
          {
            "id": "expand-btn",
            "type": "button",
            "text": "Expand controls",
            "variant": "ghost"
          }
        ]
      },
      {
        "id": "divider-controls",
        "type": "divider"
      },
      {
        "id": "controls-panel",
        "type": "frame",
        "direction": "vertical",
        "gap": 12,
        "padding": 16,
        "width": "fill",
        "children": [
          {
            "id": "controls-title",
            "type": "text",
            "text": "Controls",
            "level": "h3"
          },
          {
            "id": "color-row",
            "type": "frame",
            "direction": "horizontal",
            "gap": 12,
            "width": "fill",
            "children": [
              {
                "id": "color1",
                "type": "input",
                "label": "Color 1",
                "placeholder": "#ff6b35"
              },
              {
                "id": "color2",
                "type": "input",
                "label": "Color 2",
                "placeholder": "#a855f7"
              },
              {
                "id": "color3",
                "type": "input",
                "label": "Color 3",
                "placeholder": "#ec4899"
              }
            ]
          },
          {
            "id": "grain-input",
            "type": "input",
            "label": "Grain intensity",
            "placeholder": "0.5"
          },
          {
            "id": "blur-input",
            "type": "input",
            "label": "Blur radius",
            "placeholder": "80"
          },
          {
            "id": "animate-toggle",
            "type": "toggle",
            "label": "Animate",
            "on": true
          },
          {
            "id": "actions",
            "type": "frame",
            "direction": "horizontal",
            "gap": 8,
            "children": [
              {
                "id": "randomize-btn",
                "type": "button",
                "text": "Randomize",
                "variant": "secondary"
              },
              {
                "id": "actions-spacer",
                "type": "spacer"
              },
              {
                "id": "export-btn",
                "type": "button",
                "text": "Export",
                "variant": "primary"
              }
            ]
          }
        ]
      }
    ]
  }
}