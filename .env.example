# Specular Environment Variables
# Copy this file to .env and modify as needed.

# ── Networking ──────────────────────────────────────────────

# Port for Chrome DevTools Protocol remote debugging (default: 9229)
# SPECULAR_REMOTE_DEBUGGING_PORT=9229

# Port for the Specular control server (default: auto-assigned)
# SPECULAR_PORT=9876

# ── Agent / MCP ─────────────────────────────────────────────

# Path to the browser executable used by MCP agent tools
# Falls back to searching $PATH for common browser binaries
# AGENT_BROWSER_PATH=/usr/bin/google-chrome

# ── Crash & error reporting ─────────────────────────────────

# Sentry DSN for main-process + renderer error reporting.
# Leave unset to disable Sentry entirely (safe default for dev).
# Get this from https://sentry.io → Project → Settings → Client Keys (DSN)
# SENTRY_DSN=https://xxxxx@oYYYYY.ingest.sentry.io/ZZZZZ

# ── Debug flags ─────────────────────────────────────────────

# Enable verbose CDP proxy logging (default: off)
# SPECULAR_DEBUG_CDP_PROXY=1

# Enable CDP proxy timing instrumentation (default: off)
# SPECULAR_DEBUG_CDP_PROXY_TIMING=1

# Enable selection debugging across main + preload (default: off)
# CANVAS_DEBUG_SELECTION=1

# Enable comment badge debugging (default: off)
# CANVAS_DEBUG_COMMENT_BADGES=1

# Enable devtools panel debugging (default: off)
# CANVAS_DEBUG_DEVTOOLS_PANEL=1

# ── Code Signing (CI only) ──────────────────────────────────

# These are used by the release workflow and electron-forge.
# You do NOT need them for local development.
#
# APPLE_ID=your-apple-id@example.com
# APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=XXXXXXXXXX
# CSC_LINK=base64-encoded-p12-certificate
# CSC_KEY_PASSWORD=certificate-password
