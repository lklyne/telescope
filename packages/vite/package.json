{
  "name": "@telescope/vite",
  "version": "0.0.0",
  "private": true,
  "description": "Vite plugin that lets Telescope render single React components live from your repo.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "devDependencies": {
    "vite": "^8.0.10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/bootstrap.client.js dist/bootstrap.client.js",
    "prepare": "pnpm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
