{
  "version": "1.0",
  "theme": "light",
  "root": {
    "id": "root",
    "type": "frame",
    "direction": "vertical",
    "gap": 0,
    "width": "fill",
    "height": "fill",
    "children": [
      {
        "id": "header",
        "type": "frame",
        "direction": "horizontal",
        "padding": [12, 16],
        "gap": 12,
        "width": "fill",
        "children": [
          { "id": "logo", "type": "text", "text": "Acme App", "level": "h3" },
          { "id": "spacer1", "type": "spacer" },
          { "id": "nav-home", "type": "button", "text": "Home", "variant": "ghost" },
          { "id": "nav-about", "type": "button", "text": "About", "variant": "ghost" },
          { "id": "login-btn", "type": "button", "text": "Log In", "variant": "primary" }
        ]
      },
      { "id": "divider1", "type": "divider" },
      {
        "id": "body",
        "type": "frame",
        "direction": "horizontal",
        "gap": 0,
        "width": "fill",
        "height": "fill",
        "children": [
          {
            "id": "sidebar",
            "type": "frame",
            "direction": "vertical",
            "padding": 16,
            "gap": 8,
            "width": 200,
            "children": [
              { "id": "search", "type": "input", "placeholder": "Search..." },
              { "id": "nav1", "type": "button", "text": "Dashboard", "variant": "secondary" },
              { "id": "nav2", "type": "button", "text": "Settings", "variant": "ghost" },
              { "id": "nav3", "type": "button", "text": "Profile", "variant": "ghost" }
            ]
          },
          {
            "id": "content",
            "type": "frame",
            "direction": "vertical",
            "padding": 24,
            "gap": 16,
            "width": "fill",
            "children": [
              { "id": "title", "type": "text", "text": "Welcome back!", "level": "h1" },
              { "id": "subtitle", "type": "text", "text": "Here's what's new in your workspace.", "level": "body" },
              {
                "id": "actions",
                "type": "frame",
                "direction": "horizontal",
                "gap": 8,
                "children": [
                  { "id": "new-btn", "type": "button", "text": "New Project", "variant": "primary" },
                  { "id": "import-btn", "type": "button", "text": "Import", "variant": "secondary" }
                ]
              },
              { "id": "hero-img", "type": "image", "width": 400, "height": 200, "alt": "Dashboard preview" },
              {
                "id": "options",
                "type": "frame",
                "direction": "vertical",
                "gap": 12,
                "children": [
                  { "id": "opt-notify", "type": "toggle", "label": "Email notifications", "on": true },
                  { "id": "opt-dark", "type": "checkbox", "label": "Dark mode", "checked": false },
                  { "id": "opt-lang", "type": "dropdown", "label": "Language", "placeholder": "Select language...", "options": ["English", "Spanish", "French", "German"] }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
